<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#111111">
<title>Glow Up</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="../glowup-icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--bg:#111;--card:#1a1a1a;--border:#252525;--accent:#e8734a;--text:#eee;--sub:#888;--dim:#555;--green:#4ade80;--blue:#60a5fa;--purple:#a78bfa;--yellow:#eab308;--pink:#f472b6;--r:14px}
html{background:var(--bg)}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100dvh;max-width:500px;margin:0 auto;padding-bottom:90px;overscroll-behavior:none}
button:active{transform:scale(.97)}
input:focus{border-color:var(--accent)!important;box-shadow:0 0 0 2px rgba(232,115,74,0.15)}

/* ─── HEADER ─── */
.hdr{padding:20px 16px 14px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg);z-index:50;border-bottom:1px solid var(--border)}
.hdr-left{display:flex;align-items:center;gap:10px}
.hdr-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#f472b6,var(--accent));display:flex;align-items:center;justify-content:center;font-size:18px}
.hdr h1{font-size:18px;font-weight:700;letter-spacing:-.3px}
.hdr h1 small{font-size:11px;color:var(--sub);font-weight:400;display:block;margin-top:1px}
.streak-pill{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:5px}
.streak-pill em{font-style:normal;color:var(--accent);font-variant-numeric:tabular-nums}

/* ─── LEVEL BAR ─── */
.level-wrap{padding:12px 16px 4px}
.level-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.level-tag{font-size:11px;font-weight:700;padding:3px 10px;border-radius:6px}
.level-xp{font-size:11px;color:var(--sub);font-variant-numeric:tabular-nums}
.level-bar{height:6px;background:var(--card);border-radius:3px;overflow:hidden}
.level-fill{height:100%;border-radius:3px;transition:width .5s ease}

/* ─── TABS ─── */
.tabs{display:flex;gap:4px;padding:10px 16px 6px;overflow-x:auto;position:sticky;top:63px;background:var(--bg);z-index:40}
.tabs::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;padding:8px 14px;border-radius:var(--r);border:1px solid var(--border);background:var(--card);text-align:center;cursor:pointer;transition:all .15s;position:relative;overflow:hidden}
.tab.active{border-color:var(--accent)}
.tab.active .tab-emoji{transform:scale(1.1)}
.tab.complete::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--green);border-radius:0 0 4px 4px}
.tab-emoji{font-size:16px;display:block;margin-bottom:2px;transition:transform .15s}
.tab-sub{font-size:9px;color:var(--sub);font-weight:600;font-variant-numeric:tabular-nums}
.tab.active .tab-sub{color:var(--accent)}

/* ─── PROGRESS ─── */
.prog-wrap{padding:6px 16px 0}
.prog-bar{height:5px;background:var(--card);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--pink));border-radius:3px;transition:width .35s ease}
.prog-label{font-size:12px;color:var(--sub);padding:6px 16px 0;text-align:center}
.prog-label b{color:var(--accent)}

/* ─── LIST ─── */
.list{padding:6px 16px}
.zone{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.2px;padding:18px 0 8px;display:flex;align-items:center;gap:8px}
.zone::after{content:'';flex:1;height:1px;background:var(--border)}

.exo{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:8px;display:flex;gap:12px;transition:all .15s ease;cursor:pointer;user-select:none;animation:fadeUp .3s ease both}
.exo:active{transform:scale(.985)}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.exo.done{border-color:rgba(74,222,128,.25);background:rgba(74,222,128,.04)}
.exo.done .exo-name{opacity:.5;text-decoration:line-through}
.exo.done .exo-sub{opacity:.4}
.chk{width:24px;height:24px;border-radius:7px;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s ease;margin-top:1px}
.exo.done .chk{background:var(--green);border-color:var(--green)}
.exo.done .chk::after{content:'✓';color:#111;font-size:13px;font-weight:700}
.exo-body{flex:1;min-width:0}
.exo-name{font-size:14px;font-weight:600;line-height:1.3;transition:all .15s}
.exo-sub{font-size:12px;color:var(--sub);margin-top:2px}
.exo-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.tag{font-size:10px;padding:3px 8px;border-radius:6px;font-weight:500;white-space:nowrap}
.tag.when{background:rgba(232,115,74,.1);color:var(--accent)}
.tag.freq{background:rgba(255,255,255,.05);color:var(--sub)}
.tag.impact{background:rgba(244,114,182,.1);color:var(--pink)}

.form-btn{background:none;border:1px solid var(--border);border-radius:8px;padding:6px 10px;color:var(--sub);font-size:11px;font-family:inherit;cursor:pointer;flex-shrink:0;align-self:center;transition:all .15s;font-weight:500}
.form-btn:active{border-color:var(--accent);color:var(--accent)}

/* ─── BOTTOM BAR ─── */
.bot{position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);padding:10px 16px calc(10px + env(safe-area-inset-bottom));display:flex;gap:8px;z-index:30;max-width:500px;margin:0 auto}
.bot-btn{flex:1;padding:10px 8px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg);text-align:center;font-family:inherit;cursor:pointer;transition:all .15s}
.bot-btn:active{background:var(--card)}
.bot-val{font-size:18px;font-weight:700;display:block;margin-bottom:1px;color:var(--text);font-variant-numeric:tabular-nums}
.bot-val.or{color:var(--accent)}
.bot-lbl{font-size:10px;color:var(--sub);font-weight:500}

/* ─── MODAL ─── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;display:flex;align-items:flex-end;justify-content:center;backdrop-filter:blur(6px);opacity:0;pointer-events:none;transition:opacity .2s}
.modal-bg.show{opacity:1;pointer-events:auto}
.modal{background:#1e1e1e;border-radius:20px 20px 0 0;padding:28px 20px 36px;width:100%;max-width:500px;max-height:75dvh;overflow-y:auto;transform:translateY(100%);transition:transform .25s ease}
.modal-bg.show .modal{transform:translateY(0)}
.modal-pill{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px}
.modal h3{font-size:17px;font-weight:700}
.modal .m-cat{font-size:13px;color:var(--pink);margin:2px 0 16px}
.modal .m-row{display:flex;gap:12px;margin-bottom:14px}
.modal .m-detail{flex:1;background:var(--bg);border-radius:10px;padding:10px 12px}
.modal .m-detail-label{font-size:10px;color:var(--sub);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px}
.modal .m-detail-val{font-size:13px;font-weight:600}
.modal .m-desc{font-size:13px;color:var(--sub);line-height:1.65;margin-bottom:14px}
.modal .m-tip{background:rgba(244,114,182,.08);border-left:3px solid var(--pink);padding:10px 14px;border-radius:0 10px 10px 0;font-size:12px;color:var(--text);line-height:1.55;margin-bottom:20px}
.modal-close{width:100%;padding:14px;border-radius:var(--r);background:var(--accent);color:#fff;border:none;font-size:14px;font-weight:600;font-family:inherit;cursor:pointer}
.modal-close:active{opacity:.85}

/* ─── CALENDAR ─── */
.cal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(6px);opacity:0;pointer-events:none;transition:opacity .2s}
.cal-bg.show{opacity:1;pointer-events:auto}
.cal{background:#1e1e1e;border-radius:20px;padding:24px 20px;width:calc(100% - 32px);max-width:400px}
.cal h3{font-size:16px;font-weight:700;text-align:center;margin-bottom:16px}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:16px}
.cal-dl{text-align:center;font-size:10px;color:var(--sub);padding:4px 0;font-weight:600}
.cal-c{aspect-ratio:1;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--sub);font-variant-numeric:tabular-nums}
.cal-c.e{opacity:0}
.cal-c.full{background:var(--accent);color:#fff;font-weight:600}
.cal-c.part{background:rgba(232,115,74,.25);color:var(--accent);font-weight:600}
.cal-c.today{box-shadow:inset 0 0 0 2px var(--accent)}
.cal-close{width:100%;padding:12px;border-radius:var(--r);background:var(--border);color:var(--text);border:none;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-left">
    <div class="hdr-icon">✨</div>
    <h1>Glow Up<small>Le playbook complet</small></h1>
  </div>
  <div class="streak-pill">🔥 <em id="sStreak">0</em>j</div>
</div>

<div class="level-wrap" id="levelWrap"></div>
<div class="tabs" id="eTabs"></div>
<div class="prog-wrap"><div class="prog-bar"><div class="prog-fill" id="eProgFill"></div></div></div>
<div class="prog-label" id="eProgLabel"></div>
<div class="list" id="eList"></div>

<div class="bot">
  <button class="bot-btn" onclick="openCal()"><span class="bot-val or" id="sDays">0</span><span class="bot-lbl">jours actifs</span></button>
  <button class="bot-btn" onclick="resetDay()"><span class="bot-val">↺</span><span class="bot-lbl">reset jour</span></button>
  <button class="bot-btn" onclick="openCal()"><span class="bot-val" id="sWeek">0/7</span><span class="bot-lbl">cette semaine</span></button>
</div>

<div class="modal-bg" id="mForm" onclick="this===event.target&&this.classList.remove('show')"><div class="modal" id="mFormIn"></div></div>
<div class="cal-bg" id="mCal" onclick="this===event.target&&this.classList.remove('show')"><div class="cal" id="mCalIn"></div></div>

