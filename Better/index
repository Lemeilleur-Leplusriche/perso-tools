const LEVELS=[
  {n:'Normie',min:0,color:'var(--sub)'},
  {n:'Conscient',min:15,color:'var(--blue)'},
  {n:'Discipliné',min:50,color:'var(--green)'},
  {n:'Glow Up',min:120,color:'var(--yellow)'},
  {n:'Top 10%',min:250,color:'var(--accent)'},
  {n:'Top 1%',min:500,color:'var(--pink)'},
  {n:'Légende',min:1000,color:'var(--purple)'},
];

const LS='glowup-data';
const todayK=()=>new Date().toISOString().split('T')[0];
let cat='skin';

const load=()=>{try{return JSON.parse(localStorage.getItem(LS))||{}}catch{return{}}};
const save=d=>localStorage.setItem(LS,JSON.stringify(d));
const today=()=>load()[todayK()]||{};
const check=(id,v)=>{const d=load(),k=todayK();if(!d[k])d[k]={};d[k][id]=v;save(d)};
const allEx=()=>Object.values(EX).flat();

function getXP(){
  const d=load(),a=allEx(),tot=a.length;
  let xp=0;
  Object.keys(d).forEach(k=>{if(typeof d[k]==='object'){const done=a.filter(e=>d[k]?.[e.id]).length;xp+=done}});
  return xp;
}

function getLevel(xp){
  let lv=LEVELS[0];
  for(const l of LEVELS)if(xp>=l.min)lv=l;
  const idx=LEVELS.indexOf(lv);
  const next=LEVELS[idx+1];
  return{...lv,xp,next,idx};
}

/* ═══════════ RENDER ═══════════ */
function R(){rLevel();rTabs();rList();rProg();rStats()}

function rLevel(){
  const xp=getXP(),lv=getLevel(xp);
  const pct=lv.next?Math.min((xp-lv.min)/(lv.next.min-lv.min),1):1;
  const nextLabel=lv.next?`${xp}/${lv.next.min} XP`:`${xp} XP — MAX`;
  document.getElementById("levelWrap").innerHTML=`
    <div class="level-top"><span class="level-tag" style="background:${lv.color}20;color:${lv.color}">${lv.n}</span><span class="level-xp">${nextLabel}</span></div>
    <div class="level-bar"><div class="level-fill" style="width:${Math.round(pct*100)}%;background:${lv.color}"></div></div>`;
}

function rTabs(){
  const c=today();
  document.getElementById("eTabs").innerHTML=CATS.map(ct=>{
    const exs=EX[ct.id]||[],done=exs.filter(e=>c[e.id]).length,tot=exs.length,full=done===tot&&tot>0;
    return`<div class="tab${ct.id===cat?' active':''}${full?' complete':''}" onclick="cat='${ct.id}';R()">
      <span class="tab-emoji">${ct.emoji}</span>
      <div class="tab-sub">${full?'✓':done+'/'+tot}</div>
    </div>`}).join('');
}

function rList(){
  const c=today(),exs=EX[cat]||[];
  let h='',lz='';
  exs.forEach((e,i)=>{
    if(e.zone!==lz){
      const catInfo=CATS.find(x=>x.id===cat);
      h+=`<div class="zone" style="color:${catInfo?.color||'var(--accent)'}">${e.zone}</div>`;
      lz=e.zone;
    }
    const d=c[e.id]?'done':'';
    h+=`<div class="exo ${d}" style="animation-delay:${i*40}ms" onclick="toggle('${e.id}')">
      <div class="chk"></div>
      <div class="exo-body">
        <div class="exo-name">${e.name}</div>
        <div class="exo-sub">${e.sub}</div>
        <div class="exo-tags">
          <span class="tag when">${e.when}</span>
          <span class="tag freq">${e.freq}</span>
          <span class="tag impact">⚡ ${e.impact}</span>
        </div>
      </div>
      <button class="form-btn" onclick="event.stopPropagation();openForm('${e.id}')">Guide</button>
    </div>`});
  document.getElementById("eList").innerHTML=h;
}

function rProg(){
  const c=today(),a=allEx(),done=a.filter(e=>c[e.id]).length,tot=a.length,pct=Math.round(done/tot*100);
  document.getElementById("eProgFill").style.width=pct+'%';
  document.getElementById("eProgLabel").innerHTML=`Aujourd'hui : <b>${done}/${tot}</b> — ${pct}%`;
}

function rStats(){
  const d=load(),a=allEx(),tot=a.length;
  let actDays=0;
  Object.keys(d).forEach(k=>{if(typeof d[k]==='object'&&a.filter(e=>d[k]?.[e.id]).length>=tot*.2)actDays++});
  document.getElementById("sDays").textContent=actDays;

  const now=new Date(),ws=new Date(now);ws.setDate(now.getDate()-((now.getDay()+6)%7));
  let wd=0;for(let i=0;i<7;i++){const dd=new Date(ws);dd.setDate(ws.getDate()+i);
    const k=dd.toISOString().split('T')[0];
    if(d[k]&&typeof d[k]==='object'&&a.filter(e=>d[k][e.id]).length>=tot*.2)wd++}
  document.getElementById("sWeek").textContent=wd+'/7';

  let st=0,ch=new Date();
  while(true){const k=ch.toISOString().split('T')[0];
    if(d[k]&&typeof d[k]==='object'&&a.filter(e=>d[k][e.id]).length>=tot*.2){st++;ch.setDate(ch.getDate()-1);continue}
    if(st===0&&k===todayK()){ch.setDate(ch.getDate()-1);continue}break}
  document.getElementById("sStreak").textContent=st;
}

/* ═══════════ ACTIONS ═══════════ */
function toggle(id){
  const c=today();check(id,!c[id]);
  try{navigator.vibrate(c[id]?[15]:[30])}catch(e){}
  R();
}
function resetDay(){
  if(!confirm('Reset tout aujourd\'hui ?'))return;
  const d=load();delete d[todayK()];save(d);R();
}

/* ═══════════ FORM MODAL ═══════════ */
function openForm(id){
  const e=allEx().find(x=>x.id===id);if(!e)return;
  const catInfo=CATS.find(c=>EX[c.id]?.includes(e));
  document.getElementById("mFormIn").innerHTML=`
    <div class="modal-pill"></div>
    <h3>${e.name}</h3>
    <div class="m-cat">${catInfo?.emoji||''} ${catInfo?.name||''} — ${e.zone}</div>
    <div class="m-row">
      <div class="m-detail"><div class="m-detail-label">Quand</div><div class="m-detail-val">${e.when}</div></div>
      <div class="m-detail"><div class="m-detail-label">Fréquence</div><div class="m-detail-val">${e.freq}</div></div>
      <div class="m-detail"><div class="m-detail-label">Impact</div><div class="m-detail-val">⚡ ${e.impact}</div></div>
    </div>
    <div class="m-desc">${e.form}</div>
    <div class="m-tip">💡 ${e.tip}</div>
    <button class="modal-close" onclick="document.getElementById('mForm').classList.remove('show')">Compris</button>`;
  document.getElementById("mForm").classList.add('show');
}

/* ═══════════ CALENDAR ═══════════ */
function openCal(){
  const d=load(),a=allEx(),tot=a.length,now=new Date(),y=now.getFullYear(),mo=now.getMonth();
  const dim=new Date(y,mo+1,0).getDate(),fd=(new Date(y,mo,1).getDay()+6)%7;
  const mn=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  let g=['L','M','M','J','V','S','D'].map(l=>`<div class="cal-dl">${l}</div>`).join('');
  for(let i=0;i<fd;i++)g+='<div class="cal-c e"></div>';
  for(let dd=1;dd<=dim;dd++){
    const k=`${y}-${String(mo+1).padStart(2,'0')}-${String(dd).padStart(2,'0')}`;
    const isT=k===todayK();let cls='';
    if(d[k]&&typeof d[k]==='object'){const dn=a.filter(e=>d[k][e.id]).length;if(dn>=tot*.5)cls='full';else if(dn>0)cls='part'}
    g+=`<div class="cal-c ${cls}${isT?' today':''}">${dd}</div>`}
  document.getElementById("mCalIn").innerHTML=`<h3>📅 ${mn[mo]} ${y}</h3><div class="cal-grid">${g}</div>
    <button class="cal-close" onclick="document.getElementById('mCal').classList.remove('show')">Fermer</button>`;
  document.getElementById("mCal").classList.add('show');
}

/* ═══════════ INIT ═══════════ */
R();
if("serviceWorker"in navigator)navigator.serviceWorker.register("sw.js").catch(()=>{});
let dp;window.addEventListener("beforeinstallprompt",e=>{e.preventDefault();dp=e;const b=document.createElement("button");b.id="installBtn";b.textContent="Installer";b.style.cssText="position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--accent);color:#fff;border:none;border-radius:14px;padding:12px 28px;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;z-index:200;box-shadow:0 4px 20px rgba(232,115,74,0.4)";b.onclick=async()=>{if(!dp)return;dp.prompt();await dp.userChoice;dp=null;b.remove()};document.body.appendChild(b)});
window.addEventListener("appinstalled",()=>{const b=document.getElementById("installBtn");if(b)b.remove()});
</script>
